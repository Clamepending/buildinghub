{
  "name": "vibe-research-buildinghub",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "bin": {
    "buildinghub": "./bin/buildinghub.mjs"
  },
  "scripts": {
    "build": "node bin/buildinghub.mjs build",
    "doctor": "node bin/buildinghub.mjs doctor",
    "sync:vibe-research": "node scripts/sync-vibe-research-buildings.mjs",
    "list": "node bin/buildinghub.mjs list",
    "site": "node bin/buildinghub.mjs site",
    "pack": "node bin/buildinghub.mjs pack --all",
    "test": "node --test test/*.test.mjs && node bin/buildinghub.mjs validate"
  }
}
