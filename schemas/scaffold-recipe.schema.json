{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BuildingHub Vibe Research Scaffold Recipe",
  "type": "object",
  "required": ["schema", "id", "name", "version", "description", "buildings"],
  "additionalProperties": true,
  "properties": {
    "schema": {
      "const": "vibe-research.scaffold.recipe.v1"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?$"
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "buildings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          },
          "name": {
            "type": "string"
          },
          "category": {
            "type": "string"
          },
          "source": {
            "type": "string"
          },
          "version": {
            "type": "string"
          },
          "enabled": {
            "type": "boolean"
          },
          "required": {
            "type": "boolean"
          },
          "localBindingsRequired": {
            "$ref": "#/$defs/bindings"
          }
        }
      }
    },
    "localBindingsRequired": {
      "$ref": "#/$defs/bindings"
    },
    "settings": {
      "type": "object",
      "properties": {
        "portable": {
          "type": "object"
        },
        "localBindingsRequired": {
          "$ref": "#/$defs/bindings"
        },
        "personal": {
          "$ref": "#/$defs/bindings"
        },
        "secrets": {
          "$ref": "#/$defs/bindings"
        }
      }
    },
    "communication": {
      "type": "object",
      "properties": {
        "dm": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "body": {
              "enum": ["freeform", "typed", "typed-envelope"]
            },
            "visibility": {
              "enum": ["workspace", "private", "public"]
            }
          }
        },
        "groupInboxes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "layout": {
      "type": "object"
    }
  },
  "$defs": {
    "bindings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["key"],
        "not": {
          "required": ["value"]
        },
        "properties": {
          "key": {
            "type": "string",
            "pattern": "^[A-Za-z][A-Za-z0-9_]{0,95}$"
          },
          "label": {
            "type": "string"
          },
          "sensitivity": {
            "enum": ["local", "personal", "secret", "portable", "unknown"]
          },
          "configured": {
            "type": "boolean"
          },
          "required": {
            "type": "boolean"
          }
        }
      }
    }
  }
}
