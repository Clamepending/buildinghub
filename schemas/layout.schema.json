{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BuildingHub Agent Town Layout",
  "type": "object",
  "required": ["id", "name", "version", "description", "layout"],
  "additionalProperties": true,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?$"
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "category": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "requiredBuildings": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9-]*$"
      }
    },
    "layout": {
      "type": "object",
      "required": ["decorations"],
      "properties": {
        "themeId": {
          "type": "string"
        },
        "decorations": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["itemId", "x", "y"],
            "properties": {
              "id": {
                "type": "string"
              },
              "itemId": {
                "type": "string",
                "pattern": "^[a-z0-9][a-z0-9-]*$"
              },
              "x": {
                "type": "number",
                "minimum": 0
              },
              "y": {
                "type": "number",
                "minimum": 0
              },
              "rotation": {
                "type": "integer",
                "enum": [0, 1]
              }
            }
          }
        },
        "functional": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "required": ["x", "y"],
            "properties": {
              "x": {
                "type": "number",
                "minimum": 0
              },
              "y": {
                "type": "number",
                "minimum": 0
              },
              "rotation": {
                "type": "integer",
                "enum": [0, 1]
              }
            }
          }
        }
      }
    }
  }
}
